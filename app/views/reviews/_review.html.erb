<div id="<%= dom_id review %>" class="review-card">
  <p><strong><%= review.user.userid %></strong> rated this <%= review.rating %>/5</p>
  <p><%= review.comment %></p>

  <% if logged_in? && (review.user_id == current_user.id || admin?) %>
    <p>
      <%= link_to "Edit", edit_review_path(review) %> |
      <%= button_to "Delete", review, method: :delete %>
    </p>
  <% end %>
</div>
