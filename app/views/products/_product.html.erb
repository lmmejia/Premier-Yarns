<div id="<%= dom_id product %>" class="product-detail">
  <div>
    <%= image_tag(product.image_url, width: 200) %>
  </div>
  <div>
    <strong>Name:</strong>
    <%= product.name %>
  </div>

  <div>
    <strong>Description:</strong>
    <%= product.description %>
  </div>

  <div>
    <strong>Price:</strong>
    <%= product.price %>
  </div>

</div>
